# Chave secreta usada pelo NextAuth para assinar tokens de sessão.
# Gere uma nova com: npx auth secret
AUTH_SECRET=""

# URL de conexão com o banco PostgreSQL.
# Se estiver usando Docker no WSL, rode o container com:
# docker run -d --name chatvolt_inbox-postgres -e POSTGRES_PASSWORD=0000 -e POSTGRES_DB=chatvolt_inbox -p 5432:5432 postgres
DATABASE_URL="postgresql://usuario:senha@localhost:5432/nome_do_banco"
